extends CharacterBody2D
## NPC.gd — ตัวละคร 4 คน แต่ละคนมี 50 บทพูด ไม่ซ้ำกันในแต่ละครั้งที่คุย
## บทพูดเล่าเรื่องชีวิต เหตุที่ติดหนี้ และสิ่งที่เจอในแต่ละวัน

@export var npc_id: int = 1
@export var npc_display_name: String = "นายหน้างาน"

signal player_entered(npc: CharacterBody2D)
signal player_exited(npc: CharacterBody2D)

var _all_lines: Array[String] = []
var _used_indices: Array[int] = []
var _current_dialogue: Array[String] = []
var npc_color: Color = Color(0.7, 0.15, 0.15, 1.0)

func _ready() -> void:
	add_to_group("npc")
	_build_all_lines()
	_pick_new_dialogue()
	_create_placeholder_sprite()
	$InteractArea.body_entered.connect(_on_body_entered)
	$InteractArea.body_exited.connect(_on_body_exited)

## เลือก 3 บทพูดที่ไม่ซ้ำกัน วนครบ pool แล้ว reset
func _pick_new_dialogue() -> void:
	if _used_indices.size() >= _all_lines.size():
		_used_indices.clear()
	var pool: Array[int] = []
	for i in range(_all_lines.size()):
		if not (i in _used_indices):
			pool.append(i)
	pool.shuffle()
	_current_dialogue.clear()
	var n := mini(3, pool.size())
	for i in range(n):
		_current_dialogue.append(_all_lines[pool[i]])
		_used_indices.append(pool[i])

func get_dialogue() -> Array[String]:
	return _current_dialogue

func get_npc_name() -> String:
	return npc_display_name

func get_npc_color() -> Color:
	return npc_color

