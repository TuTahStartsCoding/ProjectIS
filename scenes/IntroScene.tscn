[node name="StoryBody" type="RichTextLabel" parent="Panel/VBox" unique_id=1010676770]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/normal_font_size = 19
bbcode_enabled = true
text = "[color=#dddddd]In the neon-drenched city of Neo-Bangkok, you woke up one morning to a debt of [color=#ff6b6b]$3000 - $10000[/color] — left behind by your late uncle's failed underground business deal.

The loan sharks give you [color=#ffd93d]5 - 9 days[/color] to pay it all back. No extensions. No mercy.

You must walk the rain-soaked streets, find work where you can, and manage your [color=#6bcb77]energy[/color] carefully. Push too hard and your body gives out. Wait too long and the debt grows.

[color=#ffd93d] Controls [/color]
[color=#4ecdc4]WASD / Arrow Keys[/color]  —  Move your character
[color=#4ecdc4]E[/color]  —  Interact with NPCs and Hotel

Walk to an [color=#ffaa00]NPC[/color] and press [color=#4ecdc4]E[/color] to find work.
Walk to the [color=#00f5e9]HOTEL[/color] and press [color=#4ecdc4]E[/color] to rest and skip to the next day.[/color]"
scroll_active = false

